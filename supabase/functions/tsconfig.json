{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": "../../",
    "paths": {
      "npm:@aws-sdk/client-s3@3.735.0": ["node_modules/@aws-sdk/client-s3"],
      "npm:@aws-sdk/s3-request-presigner@3.735.0": ["node_modules/@aws-sdk/s3-request-presigner"]
    }
  },
  "include": ["./**/*.ts", "./**/*.d.ts"]
}
