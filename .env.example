VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Javni URL deployovanog frontenda (bez / na kraju). Obavezno za ispravan QR na narudžbenici
# kada PDF/štampa generišete lokalno — inače QR pokazuje na localhost.
# Primer: https://crm.vasadomena.rs
VITE_PUBLIC_APP_URL=

# Javni bazni URL R2 (r2.dev ili custom domena), BEZ završnog /. Ne sadrži secret.
VITE_R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# R2 tajne (Access Key / Secret / Account ID / bucket) NIKAD ovde — samo u:
# Supabase → Project Settings → Edge Functions → Secrets (za funkciju r2-storage)


# API ruta za slanje ponuda (server-only env)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=CRM Stolarija <onboarding@resend.dev>

# Frontend endpoint za slanje ponude (Vite klijent):
# - Lokalno uz poseban backend: npr. http://localhost:3000/api/quotes/send
# - Na produkciji (isti domen): ostavite prazno i koristi se /api/quotes/send
VITE_QUOTE_SEND_API_URL=

# SQL backup (cron + ručni admin trigger)
# Supabase service key samo na serveru (Vercel env), NIKAD u klijentu.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Cloudflare R2 (S3 kompatibilan) za SQL backup fajlove
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
