VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Javni URL deployovanog frontenda (bez / na kraju). Obavezno za ispravan QR na narudžbenici
# kada PDF/štampa generišete lokalno — inače QR pokazuje na localhost.
# Primer: https://crm.vasadomena.rs
VITE_PUBLIC_APP_URL=

# Javni bazni URL R2 (r2.dev ili custom domena), BEZ završnog /. Ne sadrži secret.
VITE_R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# R2 tajne (Access Key / Secret / Account ID / bucket) NIKAD ovde — samo u:
# Supabase → Project Settings → Edge Functions → Secrets (za funkciju r2-storage)
